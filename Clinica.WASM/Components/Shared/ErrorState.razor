<MudPaper Class="error-state" Elevation="0">
    <div class="error-icon-wrap">
        <MudIcon Icon="@Icon" Size="Size.Large" Color="@IconColor" />
    </div>

    <MudText Typo="Typo.h6" Class="error-title">
        @Title
    </MudText>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="error-message">
            @Message
        </MudText>
    }

    @if (ShowRetry && OnRetry.HasDelegate)
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="OnRetry"
                   Class="mt-4">
            Reintentar
        </MudButton>
    }

    @if (ActionContent is not null)
    {
        <div class="error-actions">
            @ActionContent
        </div>
    }
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "Ocurrió un problema";
    [Parameter] public string Message { get; set; } = "No se pudo completar la operación solicitada.";
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.ErrorOutline;
    [Parameter] public Color IconColor { get; set; } = Color.Error;
    [Parameter] public bool ShowRetry { get; set; } = true;
    [Parameter] public EventCallback OnRetry { get; set; }
    [Parameter] public RenderFragment? ActionContent { get; set; }
}