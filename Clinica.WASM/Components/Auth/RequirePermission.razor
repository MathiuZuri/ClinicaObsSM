@inject AuthStateService AuthStateService

@if (IsChecking)
{
    <MudSkeleton Width="100%" Height="32px" />
}
else if (HasPermission)
{
    @ChildContent
}

@code {
    [Parameter] public string Permission { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool IsChecking { get; set; } = true;
    private bool HasPermission { get; set; }

    protected override async Task OnInitializedAsync()
    {
        HasPermission = await AuthStateService.TienePermisoAsync(Permission);
        IsChecking = false;
    }
}