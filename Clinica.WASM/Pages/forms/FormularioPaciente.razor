@page "/panel/pacientes/nuevo"
@page "/panel/pacientes/editar/{Id:guid}"
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container" style="max-width: 900px; margin-top: 24px; margin-bottom: 50px;">
    
    <div style="margin-bottom: 20px;">
        <button class="btn-mini secondary" @onclick="Volver">⬅️ Volver al listado</button>
        <h2 style="margin: 12px 0 0; color: var(--ink);">
            @(EsModoEdicion ? "✏️ Editar Ficha de Paciente" : "📝 Registro de Nueva Paciente")
        </h2>
    </div>

    @if (cargandoDatos)
    {
        <div class="card" style="text-align:center; padding: 40px;">⏳ Cargando información de la paciente...</div>
    }
    else
    {
        <div class="form-sheet">
            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div class="badge warn" style="width: 100%; margin-bottom: 20px; padding: 12px;">
                    ⚠️ @mensajeError
                </div>
            }

            <div class="section-header"><span>🆔</span> Identificación del Sistema</div>
            <div class="grid-form">
                <div class="col-3">
                    <label class="required">DNI</label>
                    <input type="text" @bind="modelo.DNI" maxlength="8" disabled="@EsModoEdicion" placeholder="8 dígitos" />
                </div>
                <div class="col-3">
                    <label class="required">N° Historia Clínica</label>
                    <input type="text" @bind="modelo.NumeroHC" disabled="@EsModoEdicion" placeholder="Ej: HC-2024-001" />
                </div>
            </div>

            <div class="section-header"><span>👤</span> Información Personal</div>
            <div class="grid-form">
                <div class="col-6">
                    <label class="required">Nombres</label>
                    <input type="text" @bind="modelo.Nombres" disabled="@EsModoEdicion" placeholder="Nombres completos" />
                </div>
                <div class="col-6">
                    <label class="required">Apellidos</label>
                    <input type="text" @bind="modelo.Apellidos" disabled="@EsModoEdicion" placeholder="Apellidos paterno y materno" />
                </div>
                <div class="col-4">
                    <label class="required">Fecha de Nacimiento</label>
                    <input type="date" @bind="modelo.FechaNacimiento" disabled="@EsModoEdicion" />
                </div>
                <div class="col-2">
                    <label class="required">Sexo</label>
                    <select @bind="modelo.Sexo" disabled="@EsModoEdicion">
                        <option value="F">Femenino</option>
                        <option value="M">Masculino</option>
                    </select>
                </div>
            </div>

            <div class="section-header"><span>📞</span> Datos de Contacto y Ubicación</div>
            <div class="grid-form">
                <div class="col-4">
                    <label>Teléfono Celular</label>
                    <input type="text" @bind="modelo.Celular" placeholder="999 999 999" />
                </div>
                <div class="col-8">
                    <label>Correo Electrónico</label>
                    <input type="text" @bind="modelo.CorreoSecundario" placeholder="ejemplo@correo.com" />
                </div>
                <div class="col-12">
                    <label>Dirección de Domicilio</label>
                    <textarea @bind="modelo.Direccion" rows="2" placeholder="Av. Principal #123, Juliaca..."></textarea>
                </div>
            </div>

            <div class="toolbar" style="margin-top: 32px; justify-content: flex-end; border-top: 1px solid var(--line); padding-top: 20px;">
                <button class="btn secondary" @onclick="Volver" disabled="@procesando">Cancelar</button>
                <button class="btn" @onclick="GuardarPaciente" style="min-width: 180px;" disabled="@procesando">
                    @if (procesando) { <span>⌛ Guardando...</span> }
                    else { <span>💾 Guardar Paciente</span> }
                </button>
            </div>
        </div>
    }
</div>

<DialogoConfirmacion 
    Mostrar="mostrarExito" 
    Titulo="✅ ¡Registro Exitoso!" 
    Mensaje="La información de la paciente ha sido almacenada correctamente en el sistema."
    TextoConfirmar="Ir al Listado"
    MostrarBotonCancelar="false"
    OnConfirmar="Volver" />

@code {
    [Parameter] public Guid? Id { get; set; } // Si viene un ID, estamos editando
    
    private CrearPacienteDto modelo = new() { FechaNacimiento = DateTime.Today.AddYears(-25) };
    private bool EsModoEdicion => Id.HasValue;
    private bool cargandoDatos = false;
    private bool procesando = false;
    private bool mostrarExito = false;
    private string mensajeError = "";

    protected override async Task OnInitializedAsync()
    {
        if (EsModoEdicion)
        {
            await CargarDatosPaciente();
        }
    }

    private async Task CargarDatosPaciente()
    {
        cargandoDatos = true;
        try
        {
            var p = await Http.GetFromJsonAsync<PacienteResponseDto>($"api/pacientes/{Id}");
            if (p != null)
            {
                // Mapeamos los datos recibidos al modelo del formulario
                modelo.DNI = p.DNI;
                modelo.NumeroHC = p.NumeroHC;
                modelo.Nombres = p.Nombres;
                modelo.Apellidos = p.Apellidos;
                modelo.FechaNacimiento = p.FechaNacimiento;
                modelo.Celular = p.Celular;
                // Nota: Faltarían otros campos si el DTO de respuesta fuera más completo
            }
        }
        catch { mensajeError = "No se pudo recuperar la información de la paciente."; }
        finally { cargandoDatos = false; }
    }

    private async Task GuardarPaciente()
    {
        procesando = true;
        mensajeError = "";

        try
        {
            HttpResponseMessage respuesta;
            
            if (EsModoEdicion)
            {
                var updateDto = new { modelo.Celular, modelo.CorreoSecundario, modelo.Direccion };
                respuesta = await Http.PutAsJsonAsync($"api/pacientes/{Id}/contacto", updateDto);
            }
            else
            {
                // El UsuarioId debería venir del Auth, por ahora uno de prueba
                modelo.UsuarioId = Guid.Parse("00000000-0000-0000-0000-000000000000"); 
                respuesta = await Http.PostAsJsonAsync("api/pacientes", modelo);
            }

            if (respuesta.IsSuccessStatusCode)
            {
                mostrarExito = true;
            }
            else
            {
                // Capturamos el error de DNI duplicado que configuramos en el Backend
                var errorObj = await respuesta.Content.ReadFromJsonAsync<dynamic>();
                mensajeError = errorObj?.GetProperty("mensaje").GetString() ?? "Error al guardar.";
            }
        }
        catch { mensajeError = "Error de conexión con el servidor."; }
        finally { procesando = false; }
    }

    private void Volver() => Nav.NavigateTo("/panel/pacientes");

    // DTO interno para el formulario
    public class CrearPacienteDto
    {
        public Guid UsuarioId { get; set; }
        public string DNI { get; set; } = "";
        public string NumeroHC { get; set; } = "";
        public string Nombres { get; set; } = "";
        public string Apellidos { get; set; } = "";
        public DateTime FechaNacimiento { get; set; }
        public string Sexo { get; set; } = "F";
        public string? Celular { get; set; }
        public string? CorreoSecundario { get; set; }
        public string? Direccion { get; set; }
    }
    
    public record PacienteResponseDto(Guid Id, string DNI, string NumeroHC, string Nombres, string Apellidos, DateTime FechaNacimiento, string? Celular);
}