@page "/panel/citas"
@inject HttpClient Http

<div class="container" style="max-width: 1000px; margin-top: 24px; margin-bottom: 50px;">

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="badge warn" style="margin-bottom: 16px; display: block; padding: 12px; font-size: 1rem;">
            ⚠️ <strong>Atención:</strong> @mensajeError
        </div>
    }
    @if (citaGuardadaConExito)
    {
        <div class="badge ok" style="margin-bottom: 16px; display: block; padding: 12px; font-size: 1rem;">
            ✅ <strong>¡Éxito!</strong> La operación se realizó correctamente.
        </div>
    }

    @if (!mostrandoFormulario)
    {
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <div>
                <h2 style="margin:0; color: var(--ink);">📋 Citas Agendadas</h2>
                <p class="muted" style="margin: 4px 0 0;">Gestión de atenciones programadas.</p>
            </div>
            <button class="btn" @onclick="AbrirFormularioNuevo">➕ Nueva Cita</button>
        </div>

        <div class="card" style="padding: 0; overflow: hidden;">
            @if (cargandoLista)
            {
                <div style="padding: 30px; text-align: center;">⏳ Cargando citas desde el servidor...</div>
            }
            else if (!listaCitas.Any())
            {
                <div class="empty-state" style="margin: 20px;">
                    <div style="font-size: 2rem;">📅</div>
                    <h3 style="margin: 8px 0 4px; color: var(--ink);">No hay citas agendadas</h3>
                    <p>Haga clic en "Nueva Cita" para registrar la primera atención.</p>
                </div>
            }
            else
            {
                <table class="table table-hover" style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead style="background: var(--bg);">
                        <tr style="border-bottom: 2px solid var(--line); color: var(--ink);">
                            <th style="padding: 12px 20px;">Fecha y Hora</th>
                            <th style="padding: 12px 8px;">Paciente (ID)</th>
                            <th style="padding: 12px 8px;">Servicio</th>
                            <th style="padding: 12px 20px; text-align: right;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cita in listaCitas)
                        {
                            <tr style="border-bottom: 1px solid var(--line);">
                                <td style="padding: 12px 20px; font-weight: 600;">
                                    @(cita.FechaHoraProgramada?.ToString("dd/MM/yyyy HH:mm") ?? "Sin fecha")
                                </td>
                                <td style="padding: 12px 8px; font-family: monospace;" title="@cita.PacienteId">
                                    @(cita.PacienteId != Guid.Empty ? cita.PacienteId.ToString().Substring(0, 8) : "N/A")
                                </td>
                                <td style="padding: 12px 8px;">@cita.Servicio</td>
                                <td style="padding: 12px 20px; text-align: right;">
                                    <button class="btn-mini secondary" title="Editar" @onclick="() => AbrirFormularioEdicion(cita)">✏️</button>
                                    <button class="btn-mini" style="background: var(--red); border-color: var(--red); color: white;" title="Borrar" @onclick="() => EliminarCita(cita.Id)">🗑️</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
    else
    {
        <div style="margin-bottom: 20px;">
            <button class="btn-mini secondary" @onclick="CerrarFormulario">⬅️ Volver al listado</button>
            <h2 style="margin: 12px 0 0; color: var(--ink);">
                @(estaEditando ? "✏️ Editar Cita" : "📅 Agendar Nueva Cita")
            </h2>
        </div>

        <div class="form-sheet">
            <div class="section-header"><span>👤</span> Datos del Paciente</div>
            <div class="grid-form">
                <div class="col-12">
                    <label>ID del Paciente</label>
                    <input type="text" @bind="nuevaCita.PacienteId" placeholder="Ingrese el UUID del paciente..." class="grow" style="font-family: monospace;" disabled="@estaEditando" />
                    @if (estaEditando)
                    {
                        <span class="muted" style="font-size: 0.8rem; margin-top: 4px; display: block;">* El paciente no se puede cambiar al editar una cita.</span>
                    }
                </div>
            </div>

            <div class="section-header"><span>🩺</span> Detalles de la Atención</div>
            <div class="grid-form">
                <div class="col-4">
                    <label>Fecha y hora de inicio</label>
                    <input type="datetime-local" @bind="nuevaCita.FechaHoraProgramada" @bind:format="yyyy-MM-ddTHH:mm" />
                </div>
                <div class="col-8">
                    <label>Servicio requerido</label>
                    <select @bind="nuevaCita.Servicio">
                        <option value="">-- Seleccione un servicio médico --</option>
                        <option value="Control prenatal">🤰 Control prenatal</option>
                        <option value="Ecografía">🖥️ Ecografía Obstétrica</option>
                        <option value="Laboratorio">🔬 Exámenes de Laboratorio</option>
                        <option value="Consejería">🗣️ Consejería / Planificación</option>
                    </select>
                </div>
                <div class="col-12">
                    <label>Motivo de consulta / Notas adicionales</label>
                    <textarea @bind="nuevaCita.MotivoConsulta" placeholder="Ej: Paciente refiere dolor leve..." rows="3"></textarea>
                </div>
            </div>

            <div class="toolbar" style="margin-top: 32px; border-top: 1px solid var(--line); padding-top: 20px; justify-content: flex-end;">
                <button class="btn secondary" type="button" @onclick="CerrarFormulario" disabled="@estaProcesando">Cancelar</button>
                <button class="btn" @onclick="GuardarCita" disabled="@estaProcesando" style="min-width: 150px;">
                    @if (estaProcesando) { <span>⏳ Procesando...</span> }
                    else { <span>@(estaEditando ? "💾 Actualizar Cita" : "💾 Confirmar Cita")</span> }
                </button>
            </div>
        </div>
    }
</div>

@code {
    // --- ESTADO DE LA UI ---
    private bool cargandoLista = true;
    private bool estaProcesando = false;
    private bool estaEditando = false;
    private bool mostrandoFormulario = false; // NUEVO: Interruptor de vistas
    private Guid citaEditandoId = Guid.Empty;
    
    private bool citaGuardadaConExito = false;
    private string mensajeError = "";

    // --- MODELOS ---
    private CrearCitaDto nuevaCita = new CrearCitaDto { FechaHoraProgramada = DateTime.Now };
    private List<CitaResponseDto> listaCitas = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarListaCitas();
    }

    // --- MÉTODOS DE APOYO (UX VISUAL) ---
    private void AbrirFormularioNuevo()
    {
        PrepararNuevaCita();
        mostrandoFormulario = true;
    }

    private void AbrirFormularioEdicion(CitaResponseDto cita)
    {
        PrepararEdicion(cita);
        mostrandoFormulario = true;
    }

    private void CerrarFormulario()
    {
        mostrandoFormulario = false;
        mensajeError = "";
    }

    // --- MÉTODOS READ ---
    private async Task CargarListaCitas()
    {
        cargandoLista = true;
        try
        {
            var citas = await Http.GetFromJsonAsync<List<CitaResponseDto>>("api/citas");
            if (citas != null) listaCitas = citas;
        }
        catch (Exception) { mensajeError = "No se pudo cargar la lista de citas."; }
        finally { cargandoLista = false; }
    }

    // --- MÉTODOS CREATE / UPDATE (LÓGICA INTACTA) ---
    private async Task GuardarCita()
    {
        estaProcesando = true;
        mensajeError = "";
        citaGuardadaConExito = false;

        try
        {
            if (string.IsNullOrEmpty(nuevaCita.Servicio) || nuevaCita.PacienteId == Guid.Empty)
            {
                mensajeError = "Por favor, asigne un paciente y seleccione el servicio médico.";
                return;
            }

            HttpResponseMessage respuesta;

            if (estaEditando)
                respuesta = await Http.PutAsJsonAsync($"api/citas/{citaEditandoId}", nuevaCita);
            else
                respuesta = await Http.PostAsJsonAsync("api/citas", nuevaCita);

            if (respuesta.IsSuccessStatusCode)
            {
                citaGuardadaConExito = true;
                PrepararNuevaCita(); 
                await CargarListaCitas(); 
                mostrandoFormulario = false; // Regresa a la lista al guardar con éxito
            }
            else
            {
                var error = await respuesta.Content.ReadFromJsonAsync<ErrorRespuesta>();
                mensajeError = error?.Mensaje ?? "Ocurrió un error al procesar la solicitud.";
            }
        }
        catch (Exception)
        {
            mensajeError = "Sin conexión al servidor. Verifique que la API esté en ejecución.";
        }
        finally
        {
            estaProcesando = false;
        }
    }

    // --- MÉTODOS DELETE (LÓGICA INTACTA) ---
    private async Task EliminarCita(Guid id)
    {
        estaProcesando = true;
        try
        {
            var respuesta = await Http.DeleteAsync($"api/citas/{id}");
            if (respuesta.IsSuccessStatusCode) await CargarListaCitas();
            else mensajeError = "No se pudo eliminar la cita.";
        }
        catch (Exception) { mensajeError = "Error de conexión al intentar eliminar."; }
        finally { estaProcesando = false; }
    }

    // --- MÉTODOS PREPARACIÓN (LÓGICA INTACTA) ---
    private void PrepararEdicion(CitaResponseDto cita)
    {
        estaEditando = true;
        citaEditandoId = cita.Id;
        mensajeError = "";
        citaGuardadaConExito = false;
        
        nuevaCita = new CrearCitaDto
        {
            PacienteId = cita.PacienteId,
            FechaHoraProgramada = cita.FechaHoraProgramada ?? DateTime.Now, 
            Servicio = cita.Servicio,
            MotivoConsulta = "" 
        };
    }

    private void PrepararNuevaCita()
    {
        estaEditando = false;
        citaEditandoId = Guid.Empty;
        nuevaCita = new CrearCitaDto { FechaHoraProgramada = DateTime.Now };
        mensajeError = "";
    }

    private class ErrorRespuesta { public string Mensaje { get; set; } = ""; }
    public record CitaResponseDto(Guid Id, Guid PacienteId, DateTime? FechaHoraProgramada, string Servicio, int Estado);
}