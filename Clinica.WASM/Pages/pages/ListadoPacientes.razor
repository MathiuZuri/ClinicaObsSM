@page "/panel/pacientes"
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container" style="max-width: 1100px; margin-top: 20px;">
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h2 style="margin:0; color: var(--ink);">👥 Directorio de Pacientes</h2>
            <p class="muted" style="margin: 4px 0 0;">Gestión de gestantes y atenciones.</p>
        </div>
        <button class="btn" @onclick="IrANuevoPaciente">➕ Registrar Paciente</button>
    </div>

    <div class="search-bar-container">
        <label style="font-weight: 600; margin-bottom: 8px; display: block;">Buscar Paciente</label>
        <div class="row">
            <input type="text" class="grow" placeholder="Ingrese el número de DNI a buscar..." 
                   @bind="dniBusqueda" @bind:event="oninput" @onkeyup="VerificarEnter" style="max-width: 400px;" />
            <button class="btn secondary" @onclick="BuscarPorDni">🔍 Buscar</button>
            
            @if (buscandoFiltro)
            {
                <button class="btn-mini secondary" @onclick="LimpiarBusqueda" style="margin-left: 8px;">✖️ Limpiar Filtro</button>
            }
        </div>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        @if (cargando)
        {
            <div style="padding: 30px; text-align: center;">⏳ Cargando directorio...</div>
        }
        else if (!listaPacientes.Any())
        {
            <div class="empty-state" style="margin: 20px;">
                <div style="font-size: 2rem;">📂</div>
                <h3>No se encontraron pacientes</h3>
                <p>Intente con otro DNI o registre una nueva paciente.</p>
            </div>
        }
        else
        {
            <table class="table table-hover">
                <thead style="background: var(--bg);">
                    <tr>
                        <th style="padding-left: 20px;">DNI</th>
                        <th>Nombres y Apellidos</th>
                        <th>N° Historia Clínica</th>
                        <th>Celular</th>
                        <th style="text-align: right; padding-right: 20px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in listaPacientes)
                    {
                        <tr>
                            <td style="padding-left: 20px; font-weight: 600;">@p.DNI</td>
                            <td>@p.Nombres @p.Apellidos</td>
                            <td style="font-family: monospace;">@p.NumeroHC</td>
                            <td>@(string.IsNullOrEmpty(p.Celular) ? "Sin registro" : p.Celular)</td>
                            <td style="text-align: right; padding-right: 20px;">
                                <button class="btn-mini secondary" title="Editar Contacto" 
                                        @onclick='() => Nav.NavigateTo($"/panel/pacientes/editar/{p.Id}")'>
                                    ✏️
                                </button>
                                <button class="btn-mini" style="background: var(--red); border-color: var(--red); color: white;" 
                                        @onclick="() => PrepararBorrado(p)" title="Eliminar">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<DialogoConfirmacion 
    Mostrar="mostrarDialogoBorrar" 
    Titulo="🗑️ Confirmar Eliminación" 
    Mensaje="@mensajeBorrar"
    TextoConfirmar="Sí, Eliminar"
    EsPeligroso="true"
    OnConfirmar="ProcesarBorrado" 
    OnCancelar="CerrarDialogo" />

@code {
    private List<PacienteResponseDto> listaPacientes = new();
    private bool cargando = true;
    
    private string dniBusqueda = "";
    private bool buscandoFiltro = false;
    
    private bool mostrarDialogoBorrar = false;
    private PacienteResponseDto? pacienteABorrar;
    private string mensajeBorrar = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarTodos();
    }

    private void IrANuevoPaciente()
    {
        // Navega a la página del formulario que haremos luego
        Nav.NavigateTo("/panel/pacientes/nuevo");
    }
    
    private async Task CargarTodos()
    {
        cargando = true;
        buscandoFiltro = false;
        try
        {
            var resultado = await Http.GetFromJsonAsync<List<PacienteResponseDto>>("api/pacientes");
            listaPacientes = resultado ?? new List<PacienteResponseDto>();
        }
        catch { /* Manejar error de conexión */ }
        finally { cargando = false; }
    }

    private async Task BuscarPorDni()
    {
        if (string.IsNullOrWhiteSpace(dniBusqueda))
        {
            await CargarTodos();
            return;
        }

        cargando = true;
        buscandoFiltro = true;
        listaPacientes.Clear();
        
        try
        {
            // Llamamos a la ruta específica por DNI que creamos en el controlador
            var paciente = await Http.GetFromJsonAsync<PacienteResponseDto>($"api/pacientes/dni/{dniBusqueda}");
            if (paciente != null)
            {
                listaPacientes.Add(paciente);
            }
        }
        catch 
        { 
            // Si devuelve 404, la lista quedará vacía y mostrará el empty-state
        }
        finally { cargando = false; }
    }

    private async Task VerificarEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await BuscarPorDni();
    }

    private async Task LimpiarBusqueda()
    {
        dniBusqueda = "";
        await CargarTodos();
    }

    // --- LÓGICA DEL DIÁLOGO DE BORRADO ---
    private void PrepararBorrado(PacienteResponseDto paciente)
    {
        pacienteABorrar = paciente;
        mensajeBorrar = $"¿Está seguro que desea eliminar a la paciente {paciente.Nombres} {paciente.Apellidos} (DNI: {paciente.DNI})? Esta acción borrará permanentemente sus datos.";
        mostrarDialogoBorrar = true;
    }

    private void CerrarDialogo()
    {
        mostrarDialogoBorrar = false;
        pacienteABorrar = null;
    }

    private async Task ProcesarBorrado()
    {
        if (pacienteABorrar != null)
        {
            // Aquí iría el Http.DeleteAsync...
            // await Http.DeleteAsync($"api/pacientes/{pacienteABorrar.Id}");
            
            await LimpiarBusqueda(); // Refrescamos la tabla
        }
        CerrarDialogo();
    }

    // Récord para mapear la respuesta (Igual que en el backend)
    public record PacienteResponseDto(Guid Id, string DNI, string NumeroHC, string Nombres, string Apellidos, DateTime FechaNacimiento, string? Celular);
}